rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin-only: custom claim OR whitelisted email
    function isAdmin() {
      return request.auth != null &&
        (request.auth.token.admin == true ||
         request.auth.token.email == "bobiyatch@gmail.com");
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Quotes / devis requests: anyone can create, only admin reads/updates
    match /quotes/{quoteId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Contact form submissions: anyone can create, only admin reads
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Site content (realizations, services, metrics): admin writes, public reads
    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Realizations collection: admin writes, public reads
    match /realizations/{realizationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services / disciplines: admin writes, public reads
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site settings (hero text, company info overrides): admin writes, public reads
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
